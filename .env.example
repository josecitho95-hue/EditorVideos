# LLM
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storage
DATA_DIR=./data
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# GPU
GPU_VRAM_BUDGET_MB=7000

# Defaults LLM
DIRECTOR_MODEL=deepseek/deepseek-chat-v3
TRIAGE_MODEL=google/gemini-2.5-flash

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# FFmpeg
FFMPEG_BIN=ffmpeg
NVENC_PRESET=p4
NVENC_CQ=22

# Twitch (para poller automático)
TWITCH_CHANNEL_NAME=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Asset catalog — APIs opcionales (emotes de BTTV/7TV/FFZ no necesitan key)
# Freesound SFX: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=
# Pixabay imágenes: https://pixabay.com/api/docs/#api_key
PIXABAY_API_KEY=
